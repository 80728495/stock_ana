# RhinoFinance workflow settings
ARK_API_KEY=
RHINO_LLM_MODEL=minimax-m2.7
RHINO_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3

# Feishu push
RHINO_FEISHU_APP_ID=
RHINO_FEISHU_APP_SECRET=
RHINO_FEISHU_USER_OPEN_ID=

# Channels: comma-separated "Name|URL" pairs. Leave empty to use built-in defaults.
# Built-in defaults: RhinoFinance + NaNaShuoMeiGu
RHINO_CHANNELS=

# Optional overrides
HTTPS_PROXY=http://127.0.0.1:5782
HTTP_PROXY=http://127.0.0.1:5782
RHINO_PYTHON=
RHINO_YT_SCRIPT=
RHINO_YT_DLP=yt-dlp
RHINO_AUDIO_DIR=
RHINO_TRANSCRIPT_DIR=
RHINO_STATUS_FILE=
RHINO_MAX_VIDEOS_PER_RUN=5
RHINO_MAX_VIDEO_AGE_DAYS=5
